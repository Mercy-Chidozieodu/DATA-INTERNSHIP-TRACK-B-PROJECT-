      <column caption='Business Travel' datatype='string' name='[BusinessTravel]' role='dimension' type='nominal' />
      <column caption='Income vs Benchmark' datatype='string' name='[Calculation_1307373971677184]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;AVG([MonthlyIncome]) &gt;= 6911 &#13;&#10;THEN &#13;&#10;&quot;Above Benchmark&quot;&#13;&#10;ELSE &#13;&#10;&quot;Below Benchmark&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Promotion Gap' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1528650815004672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([YearsSinceLastPromotion])' />
      </column>
      <column caption='Training Participation' datatype='string' name='[Calculation_1528650826862593]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;[TrainingTimesLastYear] &gt; 0 &#13;&#10;THEN &#13;&#10;&quot;Yes&quot;&#13;&#10;ELSE &#13;&#10;&quot;No&quot;&#13;&#10;END' />
      </column>
      <column caption='Training Participation %' datatype='real' default-format='p0.0%' name='[Calculation_1528650827444226]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM&#13;&#10;(IF &#13;&#10;[TrainingTimesLastYear] &gt; 0 &#13;&#10;THEN &#13;&#10;1 &#13;&#10;ELSE &#13;&#10;0 &#13;&#10;END)&#13;&#10;/ COUNT([EmployeeNumber])' />
      </column>
      <column caption='Attrition Rate' datatype='real' default-format='p0.0%' name='[Calculation_1827440924532736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Attrition_Flag]) / COUNT([EmployeeNumber])' />
      </column>
      <column caption='Total Employees' datatype='integer' name='[Calculation_1827440974684162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([EmployeeNumber])' />
      </column>
      <column caption='Avg Monthly Income' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_1827440978309123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([MonthlyIncome])' />
      </column>
      <column caption='Avg Age' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_1827440985264132]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Age])' />
      </column>
      <column caption='Avg Job Satisfaction' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1827441007075334]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([JobSatisfaction])' />
      </column>
      <column caption='Satisfaction Category' datatype='string' name='[Calculation_1827441008873479]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([JobSatisfaction]) &lt; 2.5 THEN &quot;Low&quot;&#13;&#10;ELSEIF AVG([JobSatisfaction]) &lt; 3.5 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
